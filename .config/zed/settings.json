{
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all"
  },
  "buffer_font_features": {
    "liga": false,
    "calt": false
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true
  },
  "outline_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left"
  },
  "edit_predictions": {
    "mode": "subtle"
  },
  "file_types": {
    "JSON": ["site.webmanifest"],
    "JSONC": [".oxlintrc.json"]
  },
  "auto_install_extensions": {
    "biome": true,
    "tsgo": true,
    "oxc": true,
    "emmet": true,
    "rainbow-csv": true,
    "codebook": true
  },
  "language_servers": [
    "tsgo",
    "!vtsls",
    "!typescript-language-server",
    "oxlint",
    "oxfmt",
    "!biome",
    "!eslint",
    "..."
  ],
  "languages": {
    "CSS": {
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server"
      ]
    }
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    }
  }
}
